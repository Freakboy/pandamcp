{
  "name": "pandamcp",
  "version": "0.1.1",
  "description": "MCP bridge for Lightpanda/CDP browsers with stdio, SSE, and Streamable HTTP transports.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Freakboy/pandamcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Freakboy/pandamcp.git"
  },
  "bugs": {
    "url": "https://github.com/Freakboy/pandamcp/issues"
  },
  "keywords": [
    "mcp",
    "cdp",
    "lightpanda",
    "browser-automation",
    "sse",
    "stdio"
  ],
  "bin": {
    "pandamcp": "dist/cli.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "playwright-core": "^1.61.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
